# Pulse environment — copy to .env and fill in

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434

# --- NVIDIA NIM (optional; weekly digest + preference review route here if set) ---
# NVIDIA_NIM_API_KEY=nvapi-xxx
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Reddit (PRAW) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulse/0.1 by yourusername
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- Twitter / X (optional; v0.2) ---
# Official API
# TWITTER_BEARER_TOKEN=
# twitterapi.io fallback
# TWITTERAPI_IO_KEY=

# --- LinkedIn (optional; v0.2) ---
# Paste authenticated session cookie — high account-ban risk, read README
# LINKEDIN_LI_AT=

# --- GitHub (optional) ---
# GITHUB_TOKEN=ghp_xxx

# --- ntfy (self-hosted) ---
NTFY_URL=http://localhost:8080
NTFY_TOPIC=pulse-alerts

# --- Server ---
PULSE_HOST=127.0.0.1
PULSE_PORT=7878
PULSE_DB_PATH=./data/pulse.sqlite
PULSE_VECTOR_PATH=./data/lancedb
PULSE_LOG_LEVEL=INFO

# --- GPU / CPU flag ---
# Set to "cpu" to skip GPU assumptions
PULSE_COMPUTE=gpu
